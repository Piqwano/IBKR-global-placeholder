# ──────────────────────────────────────────────────────────────────────────
#  IBKR CREDENTIALS (required)
# ──────────────────────────────────────────────────────────────────────────
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# ──────────────────────────────────────────────────────────────────────────
#  TRADING MODE
# ──────────────────────────────────────────────────────────────────────────
# paper → uses port 4004 (IB Gateway paper socat)
# live  → uses port 4003 (IB Gateway live  socat)  — requires 2FA on redeploy
TRADING_MODE=paper
IB_GATEWAY_PORT=4004

IB_CLIENT_ID=10

# ──────────────────────────────────────────────────────────────────────────
#  MARKET DATA
# ──────────────────────────────────────────────────────────────────────────
# delayed → free, 15-20 min lag (reqMarketDataType=3)
# live    → requires IBKR paid subscription
IB_MARKET_DATA=delayed

# ──────────────────────────────────────────────────────────────────────────
#  RISK CONTROLS
# ──────────────────────────────────────────────────────────────────────────
# Timezone used for daily P&L reset (default NYSE)
DAILY_RESET_TZ=America/New_York

# Set RESET_MAX_DD=1 on restart to clear a persisted max-drawdown halt flag.
# Leave blank normally. Setting it to 1 explicitly acknowledges you want to
# resume trading after the bot hit the -15% from-peak halt.
RESET_MAX_DD=

# ──────────────────────────────────────────────────────────────────────────
#  STATE
# ──────────────────────────────────────────────────────────────────────────
# Where bot_state.json is written inside the container
BOT_STATE_FILE=/app/state/bot_state.json

# ──────────────────────────────────────────────────────────────────────────
#  NOTIFICATIONS (optional)
# ──────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK=
