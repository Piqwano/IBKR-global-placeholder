# ──────────────────────────────────────────────────────────────────────────
#  IBKR Gateway — credentials
# ──────────────────────────────────────────────────────────────────────────
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# ──────────────────────────────────────────────────────────────────────────
#  Trading mode
# ──────────────────────────────────────────────────────────────────────────
# paper or live
TRADING_MODE=paper

# IB Gateway Docker image auto-calculates socat port as API + 2:
#   paper: API 4002 → socat 4004  (use IB_GATEWAY_PORT=4004)
#   live:  API 4001 → socat 4003  (use IB_GATEWAY_PORT=4003)
IB_GATEWAY_PORT=4004
IB_GATEWAY_HOST=127.0.0.1
IB_CLIENT_ID=10

# delayed (free, 15–20min lag) or live (paid market data)
IB_MARKET_DATA=delayed

# ──────────────────────────────────────────────────────────────────────────
#  Risk state
# ──────────────────────────────────────────────────────────────────────────
DAILY_RESET_TZ=America/New_York
# Set to 1 to clear persisted max-DD halt on next start
RESET_MAX_DD=

BOT_STATE_FILE=bot_state.json

# ──────────────────────────────────────────────────────────────────────────
#  Orphan adoption — safe default OFF
# ──────────────────────────────────────────────────────────────────────────
# Set to 1 to allow the bot to adopt pre-existing IBKR positions that
# happen to be in the universe. Default OFF means orphans are logged and
# reported but never touched.
ADOPT_ORPHAN=

# ──────────────────────────────────────────────────────────────────────────
#  Notifications
# ──────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK=

# ──────────────────────────────────────────────────────────────────────────
#  Dashboard  (R-round additions)
# ──────────────────────────────────────────────────────────────────────────
# Port — if Railway sets PORT, dashboard uses it; else 8000
PORT=8000

# R11: bind address. Default 0.0.0.0 for Railway-exposed service.
# Set to 127.0.0.1 to restrict to loopback only (when behind a proxy).
DASHBOARD_HOST=0.0.0.0

# R11: auth token for /status, /positions, /docs endpoints.
# When set, requests must include header `X-Auth-Token: <value>`.
# /health stays unauthenticated for platform health checks.
# STRONGLY RECOMMENDED in production — without this, anyone who can reach
# the dashboard can read your positions and strategy state.
# Generate a long random value, e.g. `openssl rand -hex 32`.
DASHBOARD_AUTH_TOKEN=
