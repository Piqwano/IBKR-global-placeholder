# Global RSI Bot v2.3 — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# ⚠️  NEVER COMMIT .env TO GIT. Only this template (.env.example) is safe.
#     Run `git check-ignore .env` — it should print `.env`.
# ═══════════════════════════════════════════════════════════════════════════

# ── IBKR Gateway credentials ────────────────────────────────────────────────
# Use your LIVE credentials if TRADING_MODE=live, PAPER credentials otherwise.
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# paper | live
TRADING_MODE=paper

# Explicit account base currency override (AUD, USD, etc.). Set for non-USD accounts to prevent silent USD fallback mis-sizing.
ACCOUNT_BASE_CURRENCY=

# ── Gateway connection (bot → gateway) ──────────────────────────────────────
# gnzsnz image socat port mapping:
#   TWS live  → API 4001 → socat 4003  ← USE THIS IF TRADING_MODE=live
#   TWS paper → API 4002 → socat 4004  ← USE THIS IF TRADING_MODE=paper
IB_GATEWAY_HOST=ib-gateway
IB_GATEWAY_PORT=4004
IB_CLIENT_ID=10

# live = paid live market data     | delayed = free 15-20 min lag
IB_MARKET_DATA=delayed

# ── Trading day reset timezone ──────────────────────────────────────────────
# Controls when the daily loss-limit window rolls. NY close = default.
DAILY_RESET_TZ=America/New_York

# ── Notifications ───────────────────────────────────────────────────────────
# Discord webhook for trade alerts and critical messages. Leave blank to disable.
DISCORD_WEBHOOK=

# ── Startup flags ───────────────────────────────────────────────────────────
# Run pre-flight sanity checks before main loop. Leave ON in production.
STARTUP_SELF_TEST=1

# Set to 1 ONCE to claim orphan IBKR positions on startup (positions held in
# IBKR but not tracked in bot_state.json). Unset (default) after restart.
ADOPT_ORPHAN=

# Set to 1 ONCE to clear a persisted max-drawdown halt flag. Unset after restart.
RESET_MAX_DD=

# Operator kill-switch: set to 1/true/yes to pause NEW BUYS while keeping
# exits, reconcile, dashboard and state persistence running as normal.
# Orthogonal to the automatic daily-loss and max-drawdown halts. Useful
# during pre-FOMC windows, post-incident review, or any time you want to
# quiesce entries without tearing the bot down. Flag is read at startup,
# so edit the env var and restart to toggle.
HALT_NEW_BUYS=


# ── Dashboard ───────────────────────────────────────────────────────────────
# 0.0.0.0 exposes the dashboard to all interfaces on the host. Use 127.0.0.1
# if behind a reverse proxy or only accessing locally.
DASHBOARD_HOST=0.0.0.0

# Host-port publish (compose's DASHBOARD_EXPOSE:-8000). Change if 8000 is taken.
DASHBOARD_EXPOSE=8000

# AUTH TOKEN — REQUIRED FOR LIVE MODE (startup will refuse to proceed without).
# Generate with:   openssl rand -hex 32
# This header is required on every request except /health.
DASHBOARD_AUTH_TOKEN=

# ── Host ────────────────────────────────────────────────────────────────────
TZ=Australia/Melbourne
