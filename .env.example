# ══════════════════════════════════════════════════════════════════════
#  IBKR Global RSI Bot — environment template
#  Copy to .env and fill in.  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── IBKR credentials (used by the ib-gateway container only) ──────────
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# ── Trading mode: paper | live ────────────────────────────────────────
# IMPORTANT: port must match the mode.
#   paper mode → IB_GATEWAY_PORT=4004
#   live  mode → IB_GATEWAY_PORT=4003
TRADING_MODE=paper
IB_GATEWAY_PORT=4004

# ── Connection ────────────────────────────────────────────────────────
IB_CLIENT_ID=10

# ── Market data: live (paid) | delayed (free, 15-20 min lag) ──────────
IB_MARKET_DATA=delayed

# ── Daily-reset timezone (when the day-rollover happens) ──────────────
DAILY_RESET_TZ=America/New_York

# ── Set to 1 to clear the persisted max-DD halt flag on next start ────
RESET_MAX_DD=

# ── State file path (inside the rsi-bot container) ────────────────────
BOT_STATE_FILE=/app/state/bot_state.json

# ── Discord webhook for trade / daily-summary notifications ───────────
DISCORD_WEBHOOK=

# ── Orphan position adoption (safety-critical) ────────────────────────
# SAFETY (H4): Set to 1 ONLY when you intentionally want the bot to claim
# IBKR positions that aren't in its persisted state (e.g. after state
# reset, or when intentionally handing off a manual trade). Default
# (empty) is the safe behaviour: skip orphans with a loud warning +
# Discord alert, leaving them untouched for the operator to manage.
# Never leave this set to 1 in production unless you actively need it.
ADOPT_ORPHAN=
